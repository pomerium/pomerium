{
  "name": "pomerium-mcp-e2e",
  "version": "1.0.0",
  "description": "Container-based E2E tests for Pomerium MCP: testcontainers + real Keycloak IdP + Playwright browser sign-in + the official MCP TypeScript SDK client, against the official pomerium/pomerium container.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "testcontainers": "^12.0.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.4"
}
